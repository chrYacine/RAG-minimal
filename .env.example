# Copy this file to .env and fill the secret values locally.
# Never commit .env.
GROQ_API_KEY=replace_with_your_groq_api_key

# Optional backup keys. Leave empty if you do not have one.
GROQ_API_KEY_BACKUP=
GROQ_API_KEY_FALLBACK=

# Main RAG generation model.
GROQ_GENERATION_MODEL=llama-3.3-70b-versatile
GROQ_GENERATION_FALLBACK_MODELS=openai/gpt-oss-120b,llama-3.1-8b-instant

# Prompt-injection moderation agent.
GROQ_MODERATION_MODEL=openai/gpt-oss-safeguard-20b
GROQ_MODERATION_FALLBACK_MODELS=meta-llama/llama-prompt-guard-2-86m,meta-llama/llama-prompt-guard-2-22m

GROQ_TIMEOUT_SECONDS=30
